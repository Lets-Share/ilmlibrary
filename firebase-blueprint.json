{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the library platform.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user (matches Firebase Auth UID)."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role."
        },
        "savedBooks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of saved book IDs."
        },
        "readingProgress": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          },
          "description": "Map of book ID to the last read page number."
        },
        "bookmarks": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "description": "Map of book ID to an array of bookmarked page numbers."
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark"],
          "description": "The user's preferred theme."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created."
        }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Book": {
      "title": "Book",
      "description": "A book in the library.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier of the book."
        },
        "title": {
          "type": "string",
          "description": "The title of the book."
        },
        "author": {
          "type": "string",
          "description": "The author of the book."
        },
        "category": {
          "type": "string",
          "description": "The category/genre of the book."
        },
        "description": {
          "type": "string",
          "description": "A brief description or synopsis of the book."
        },
        "fileURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL to the PDF file in Firebase Storage."
        },
        "coverURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL to the cover image in Firebase Storage."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the book requires premium access."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "The approval status of the book."
        },
        "uploadedBy": {
          "type": "string",
          "description": "The UID of the user who uploaded the book."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the book was uploaded."
        }
      },
      "required": ["id", "title", "author", "category", "description", "fileURL", "coverURL", "isPremium", "status", "uploadedBy", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a book.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who wrote the review."
        },
        "userName": {
          "type": "string",
          "description": "The display name of the user who wrote the review."
        },
        "rating": {
          "type": "number",
          "description": "The rating given by the user (1-5)."
        },
        "text": {
          "type": "string",
          "description": "The text content of the review."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the review was created."
        }
      },
      "required": ["userId", "userName", "rating", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and settings."
    },
    "/books/{bookId}": {
      "schema": {
        "$ref": "#/entities/Book"
      },
      "description": "Stores book metadata."
    },
    "/books/{bookId}/reviews/{reviewId}": {
      "schema": {
        "$ref": "#/entities/Review"
      },
      "description": "Stores user reviews for a specific book."
    }
  }
}
